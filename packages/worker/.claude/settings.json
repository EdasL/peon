{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/send_event.py --event-type PreToolUse --source-app ${AGENT_ID:-default}"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/send_event.py --event-type PostToolUse --source-app ${AGENT_ID:-default}"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/send_event.py --event-type PostToolUseFailure --source-app ${AGENT_ID:-default}"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/send_event.py --event-type Notification --source-app ${AGENT_ID:-default}"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/send_event.py --event-type Stop --source-app ${AGENT_ID:-default}"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/send_event.py --event-type SessionEnd --source-app ${AGENT_ID:-default}"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/send_event.py --event-type SubagentStart --source-app ${AGENT_ID:-default}"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /workspace/.claude/hooks/send_event.py --event-type SubagentStop --source-app ${AGENT_ID:-default}"
          }
        ]
      }
    ]
  }
}
