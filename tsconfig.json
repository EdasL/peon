{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@lobu/core": ["packages/core/src/index.ts"],
      "@lobu/core/*": ["packages/core/src/*"],
      "@lobu/gateway": ["packages/gateway/src/index.ts"],
      "@lobu/gateway/*": ["packages/gateway/src/*"],
      "@lobu/worker": ["packages/worker/src/index.ts"],
      "@lobu/worker/*": ["packages/worker/src/*"]
    }
  },
  "include": ["packages/*/src/**/*"],
  "exclude": [
    "node_modules",
    "packages/web/**/*",
    "packages/*/src/__tests__/**/*",
    "packages/gateway/src/routes/public/settings-page/**/*",
    "packages/gateway/src/routes/public/history-page/**/*"
  ]
}
